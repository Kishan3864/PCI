# ── Database ────────────────────────────────────────────────────────────────
# Postgres 16 connection string (docker-compose default shown)
DATABASE_URL=postgres://scriptproof:scriptproof@localhost:5433/scriptproof

# ── App URLs ────────────────────────────────────────────────────────────────
# Public base URL of the web app (used in emails, auth callbacks, review links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Better Auth base URL (usually same as NEXT_PUBLIC_APP_URL)
BETTER_AUTH_URL=http://localhost:3000
# Secret for Better Auth session/token signing — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# ── Email ───────────────────────────────────────────────────────────────────
# 'smtp' for local dev (Mailhog via docker-compose) | 'resend' for production
EMAIL_PROVIDER=smtp
# From address for all outgoing mail
EMAIL_FROM=ScriptProof <notify@scriptproof.local>
# Resend API key (required when EMAIL_PROVIDER=resend)
RESEND_API_KEY=
# SMTP settings (required when EMAIL_PROVIDER=smtp; Mailhog defaults shown)
SMTP_HOST=localhost
SMTP_PORT=1025

# ── Worker / crawler ────────────────────────────────────────────────────────
# Public URL of the bot info page advertised in the crawler User-Agent
BOT_INFO_URL=https://scriptproof.local/bot
# Port for the local fixture checkout pages served in test mode
FIXTURE_PORT=4820

# ── Test mode (never enable in production) ──────────────────────────────────
# '1' allows http/localhost site domains, mocked DNS verification, fixture server
SCRIPTPROOF_TEST_MODE=
# JSON map of domain -> TXT record values used instead of live DNS in test mode,
# e.g. {"localhost:4820":["scriptproof-verify=abc123"]}
MOCK_TXT_RECORDS=

# ── Billing ─────────────────────────────────────────────────────────────────
# 'dodo' (default) | 'lemonsqueezy'. When the chosen provider's API key is unset,
# billing runs in local MOCK mode: choosing a plan simulates a successful checkout
# so the flow is testable without real keys.
BILLING_PROVIDER=dodo
# Dodo Payments (merchant of record)
DODO_API_KEY=
DODO_WEBHOOK_SECRET=
DODO_API_BASE=https://api.dodopayments.com
# Dodo product id per plan (create the products, then paste their ids)
DODO_PRODUCT_STARTER=
DODO_PRODUCT_PRO=
DODO_PRODUCT_AGENCY=
# Lemon Squeezy (only if BILLING_PROVIDER=lemonsqueezy)
LEMON_API_KEY=
LEMON_STORE_ID=
LEMON_WEBHOOK_SECRET=
LEMON_VARIANT_STARTER=
LEMON_VARIANT_PRO=
LEMON_VARIANT_AGENCY=

# ── Storage ─────────────────────────────────────────────────────────────────
# Directory for generated Evidence Pack PDFs (mounted volume in production)
STORAGE_DIR=./storage
