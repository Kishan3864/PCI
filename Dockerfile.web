# ── ScriptProof web (Next.js) ────────────────────────────────────────────────
# Build:  docker build -f Dockerfile.web -t scriptproof-web .
FROM node:22-bookworm-slim AS base
RUN corepack enable
WORKDIR /app

FROM base AS build
# Placeholder envs so module-load env checks pass during `next build`.
# Real values are provided at runtime by the platform (Railway).
ENV BETTER_AUTH_SECRET=build-time-placeholder
ENV DATABASE_URL=postgres://build:build@localhost:5432/build
ENV NEXT_PUBLIC_APP_URL=http://localhost:3000
ENV NEXT_TELEMETRY_DISABLED=1
COPY . .
RUN pnpm install --frozen-lockfile
RUN pnpm --filter web build

FROM build AS runtime
ENV NODE_ENV=production
EXPOSE 3000
CMD ["pnpm", "--filter", "web", "start", "--", "-p", "3000"]
